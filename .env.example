# ─── Obrigatório ───────────────────────────────────
# Token do bot Telegram (obtido via @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=

# O teu Chat ID pessoal (obtido via @userinfobot no Telegram)
TELEGRAM_CHAT_ID=

# ─── Opcional ──────────────────────────────────────
# Porta do servidor local (default: 8765)
# PORT=8765

# Timeout em segundos para aprovação de permissões.
# 0 (default) = sem timeout — aguarda indefinidamente até o utilizador aprovar ou rejeitar.
# Se definires um valor > 0, o pedido é recusado automaticamente ao fim desse tempo.
# Regra: TASK_TIMEOUT deve ser superior a APPROVAL_TIMEOUT quando ambos são > 0.
# APPROVAL_TIMEOUT=0

# Diretório do projeto onde o Claude Code vai trabalhar
# PROJECT_DIR=/home/user/meu-projeto

# Comando do Claude Code CLI (default: claude)
# CLAUDE_CMD=claude

# Máximo de tarefas Claude simultâneas (default: 1)
# MAX_CONCURRENT_TASKS=1

# Timeout em segundos para tarefas CLI.
# 0 (default) = sem timeout — o processo corre até terminar ou seres tu a cancelar.
# Se definires um valor > 0, o processo é morto ao fim desse tempo.
# Regra: TASK_TIMEOUT deve ser superior a APPROVAL_TIMEOUT quando ambos são > 0.
# TASK_TIMEOUT=0

# Nível de log: debug, info, warn, error (default: info)
# LOG_LEVEL=info
