# ─── Obrigatório ───────────────────────────────────
# Token do bot Telegram (obtido via @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=

# O teu Chat ID pessoal (obtido via @userinfobot no Telegram)
TELEGRAM_CHAT_ID=

# ─── Opcional ──────────────────────────────────────
# Porta do servidor local (default: 8765)
# PORT=8765

# Timeout em segundos para aprovação de permissões (default: 300 = 5 min)
# APPROVAL_TIMEOUT=300

# Diretório do projeto onde o Claude Code vai trabalhar
# PROJECT_DIR=/home/user/meu-projeto

# Comando do Claude Code CLI (default: claude)
# CLAUDE_CMD=claude

# Máximo de tarefas Claude simultâneas (default: 1)
# MAX_CONCURRENT_TASKS=1

# Timeout em segundos para tarefas CLI (default: 600 = 10 min)
# TASK_TIMEOUT=600

# Nível de log: debug, info, warn, error (default: info)
# LOG_LEVEL=info
